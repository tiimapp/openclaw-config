{
  "name": "clawdos",
  "version": "1.0.1",
  "display_name": "Windows Execution Interface for OpenClaw",
  "description": "Windows automation via Clawdos API: screen capture, mouse/keyboard input, window management, file-system operations, and shell command execution.",
  "author": "DANZIG MOE",
  "icon": "🐾",
  "license": "MIT",
  "python_requires": ">=3.10",
  "dependencies": [
    "requests>=2.28.0"
  ],
  "tools": [
    "health_check",
    "get_env",
    "screen_capture",
    "mouse_click",
    "mouse_move",
    "mouse_drag",
    "key_combo",
    "type_text",
    "input_batch",
    "window_list",
    "window_focus",
    "fs_list",
    "fs_read",
    "fs_write",
    "fs_mkdir",
    "fs_delete",
    "fs_move",
    "shell_exec"
  ],
  "config_schema": {
    "base_url": {
      "type": "string",
      "default": "http://127.0.0.1:17171",
      "description": "Clawdos service base URL"
    },
    "api_key": {
      "type": "string",
      "required": true,
      "description": "Clawdos API key (must match clawdos-config.json)"
    }
  }
}