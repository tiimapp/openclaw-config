{
  "name": "zipcracker",
  "version": "1.1.1",
  "description": "高级ZIP密码破解工具 (Hx0战队) - 支持静默Agent模式、伪加密修复与掩码攻击",
  "skill": {
    "type": "cli",
    "entryPoint": "zipcracker.py",
    "commands": {
      "zipcracker": {
        "description": "破解受保护的ZIP压缩包。支持内置字典、自定义字典或掩码攻击。",
        "executable": "python3",
        "args": ["zipcracker.py", "${target}", "--agent"],
        "options": {
          "target": {
            "type": "string",
            "description": "要破解的ZIP文件路径",
            "required": true
          },
          "mask": {
            "type": "string",
            "description": "掩码规则(如?d?d?d表示3位数字)。使用前置参数 -m",
            "required": false
          },
          "dict": {
            "type": "string",
            "description": "自定义字典的路径",
            "required": false
          }
        }
      }
    }
  }
}